#!/bin/bash
# Pterodactyl 共通ライブラリ

# カラー定義
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# 進捗表示関数
show_progress() {
    local current=$1
    local total=$2
    local message=$3
    local percent=$((current * 100 / total))
    local bar_size=$((percent / 5))
    local bar=$(printf "%${bar_size}s" | tr ' ' '#')
    local space=$(printf "%$((20 - bar_size))s")
    
    printf "\r${BLUE}[${bar}${space}] ${percent}%% - ${YELLOW}%s${NC}" "$message"
}

# 実行権限チェック（sudoが必要な場合用）
check_sudo() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}エラー: このコマンドは sudo で実行してください。${NC}"
        exit 1
    fi
}
