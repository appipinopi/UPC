#!/bin/bash
# Pterodactyl 共通ライブラリ

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# 進捗表示: show_progress [現在ステップ] [総ステップ数] [説明文]
show_progress() {
    local step=$1
    local total=$2
    local msg=$3
    local percent=$((step * 100 / total))
    local bar_size=$((percent / 5))
    local bar=$(printf "%${bar_size}s" | tr ' ' '#')
    local space=$(printf "%$((20 - bar_size))s")
    
    printf "\r${BLUE}[${bar}${space}] ${percent}%% - Step ${step}/${total}: ${YELLOW}%s${NC}" "$msg"
}

# 管理者権限チェック
check_sudo() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}エラー: sudo をつけて実行してください。${NC}"
        exit 1
    fi
}
