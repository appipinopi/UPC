#!/bin/bash
source /usr/local/bin/pt-lib
check_sudo

REPO="appipinopi/UPC"
VERSION_FILE="/usr/local/bin/.upc_version"
CURRENT_VERSION=$(cat "$VERSION_FILE" 2>/dev/null || echo "0.0.0")

echo -e "${GREEN}=== Pterodactyl CM Update System ===${NC}"
echo -e "${BLUE}全 4 工程を確認します...${NC}\n"

# Step 1: 最新バージョンの取得
show_progress 1 4 "GitHubから最新リリースを確認中..."
LATEST_VERSION=$(curl -s "https://api.github.com/repos/$REPO/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')

if [ -z "$LATEST_VERSION" ]; then
    echo -e "\n${RED}エラー: 最新バージョンの取得に失敗しました。${NC}"
    exit 1
fi
sleep 1

# Step 2: バージョン比較
show_progress 2 4 "バージョンを比較中 ($CURRENT_VERSION -> $LATEST_VERSION)..."
if [ "$CURRENT_VERSION" == "$LATEST_VERSION" ]; then
    echo -e "\n${GREEN}✔ 既に最新バージョン ($LATEST_VERSION) です。${NC}"
    exit 0
fi
sleep 1

# Step 3: ダウンロード
show_progress 3 4 "最新版をダウンロード中..."
# ここに実際のダウンロードURLや処理を記述（例としてzip取得）
# curl -L "https://github.com/$REPO/archive/refs/tags/$LATEST_VERSION.tar.gz" -o /tmp/upc.tar.gz
sleep 1

# Step 4: インストールとバージョン記録
show_progress 4 4 "システムを更新中..."
# インストール処理をここに記述
echo "$LATEST_VERSION" > "$VERSION_FILE"
sleep 1

echo -e "\n\n${GREEN}✔ [完了] $LATEST_VERSION へのアップデートが完了しました！${NC}"
